<view class="page">
  <view class="toolbar">
    <view class="title">资料库</view>
    <button class="refresh-button" loading="{{loading}}" bindtap="loadMedia">刷新</button>
  </view>

  <view class="mode-bar">
    <button class="mode-button {{previewMode === 'small' ? 'mode-button-active' : ''}}" data-mode="small" bindtap="onChangePreviewMode">小</button>
    <button class="mode-button {{previewMode === 'medium' ? 'mode-button-active' : ''}}" data-mode="medium" bindtap="onChangePreviewMode">中</button>
    <button class="mode-button {{previewMode === 'large' ? 'mode-button-active' : ''}}" data-mode="large" bindtap="onChangePreviewMode">大</button>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
  <view wx:if="{{!loading && items.length === 0}}" class="empty">暂无资料</view>

  <view class="list">
    <view wx:for="{{items}}" wx:key="id" class="item item-{{previewMode}}" data-id="{{item.id}}" bindtap="onOpenItem">
      <image wx:if="{{item.isPhoto && previewMode !== 'small'}}" class="thumb thumb-{{previewMode}}" src="{{item.previewUrl}}" mode="aspectFill" />
      <view wx:if="{{!item.isPhoto && previewMode !== 'small'}}" class="video-card thumb-{{previewMode}}">VIDEO</view>
      <view class="item-main">
        <view class="item-name">{{item.originalName}}</view>
        <view class="item-meta">{{item.fileType}} · {{item.size}} bytes</view>
        <view class="item-path">{{item.relativePath}}</view>
      </view>
      <view class="item-time">{{item.uploadedAt}}</view>
    </view>
  </view>
</view>
