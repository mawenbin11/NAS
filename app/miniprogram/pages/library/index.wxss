.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.mode-bar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.mode-button {
  margin: 0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
  font-size: 26rpx;
}

.mode-button-active {
  background: #1677ff;
  color: #ffffff;
  border-color: #1677ff;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.refresh-button {
  width: 160rpx;
  margin: 0;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.empty,
.error {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx;
  color: #667085;
  font-size: 28rpx;
}

.error {
  color: #b42318;
}

.item {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.item-medium {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 20rpx;
  align-items: start;
}

.item-large {
  padding: 20rpx;
}

.thumb {
  border-radius: 8rpx;
  background: #111827;
}

.thumb-medium {
  width: 180rpx;
  height: 140rpx;
}

.thumb-large {
  width: 100%;
  height: 520rpx;
  margin-bottom: 20rpx;
}

.video-card {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  word-break: break-all;
}

.item-meta,
.item-path,
.item-time {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  word-break: break-all;
}
