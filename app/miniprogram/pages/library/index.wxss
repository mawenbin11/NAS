.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.refresh-button {
  width: 160rpx;
  margin: 0;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.empty,
.error {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx;
  color: #667085;
  font-size: 28rpx;
}

.error {
  color: #b42318;
}

.item {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  word-break: break-all;
}

.item-meta,
.item-path,
.item-time {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  word-break: break-all;
}
