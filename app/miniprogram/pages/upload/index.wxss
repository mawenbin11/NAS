.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.section {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.subtitle,
.meta {
  margin-top: 14rpx;
  color: #667085;
  font-size: 26rpx;
  word-break: break-all;
}

.primary-button {
  margin-top: 28rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.message {
  margin-top: 22rpx;
  color: #027a48;
  font-size: 26rpx;
}

.error {
  margin-top: 22rpx;
  color: #b42318;
  font-size: 26rpx;
  word-break: break-all;
}
