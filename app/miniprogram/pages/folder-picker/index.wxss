.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.section {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
}

.path,
.empty,
.folder-path {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  word-break: break-all;
}

.folder-action {
  height: 84rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1677ff;
  color: #ffffff;
  border: 1rpx solid #1677ff;
  border-radius: 8rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.folder-action-disabled {
  opacity: 0.7;
}

.secondary-button {
  margin-top: 20rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.folder {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef0f3;
}

.folder-name {
  color: #172033;
  font-size: 30rpx;
  font-weight: 600;
}

.error {
  margin-top: 18rpx;
  color: #b42318;
  font-size: 24rpx;
}
