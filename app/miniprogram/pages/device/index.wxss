.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.section {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-header,
.device-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-header {
  margin-bottom: 18rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
}

.input {
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.primary-button {
  margin-top: 20rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.refresh-button {
  width: 140rpx;
  margin: 0;
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.device-card {
  position: relative;
  padding: 22rpx;
  margin-top: 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  background: #ffffff;
}

.device-card-offline {
  opacity: 0.62;
}

.device-name {
  font-size: 30rpx;
  font-weight: 700;
}

.meta,
.empty {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  word-break: break-all;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  flex: 0 0 auto;
}

.status-online {
  background: #ecfdf3;
  color: #027a48;
}

.status-offline {
  background: #f2f4f7;
  color: #667085;
}

.error {
  margin-top: 18rpx;
  color: #b42318;
  font-size: 24rpx;
}
