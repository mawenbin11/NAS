.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.section {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.input {
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.primary-button {
  margin-top: 20rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.device-card {
  position: relative;
  padding: 22rpx;
  margin-top: 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.device-name {
  font-size: 30rpx;
  font-weight: 700;
}

.meta,
.empty {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  word-break: break-all;
}

.current-badge {
  display: inline-block;
  margin-top: 14rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #ecfdf3;
  color: #027a48;
  font-size: 22rpx;
}

.error {
  margin-top: 18rpx;
  color: #b42318;
  font-size: 24rpx;
}
