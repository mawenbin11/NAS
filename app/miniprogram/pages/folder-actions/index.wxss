.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.section,
.empty {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
}

.meta,
.preview-name,
.item-meta,
.item-path,
.item-time,
.empty {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  word-break: break-all;
}

.primary-button {
  margin-top: 24rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.secondary-button {
  margin-top: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.confirm-button,
.cancel-button,
.refresh-button {
  border-radius: 8rpx;
  font-size: 26rpx;
}

.confirm-button {
  background: #12b76a;
  color: #ffffff;
}

.cancel-button,
.refresh-button {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.preview {
  margin-top: 24rpx;
}

.preview-image,
.preview-video {
  width: 100%;
  height: 500rpx;
  border-radius: 8rpx;
  background: #111827;
}

.message {
  margin-top: 22rpx;
  color: #027a48;
  font-size: 26rpx;
}

.error {
  margin-top: 22rpx;
  color: #b42318;
  font-size: 26rpx;
  word-break: break-all;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.refresh-button {
  width: 160rpx;
  margin: 0;
}

.mode-bar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.mode-tab {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.mode-tab-active {
  background: #1677ff;
  color: #ffffff;
  border-color: #1677ff;
}

.item {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.item-medium {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 20rpx;
  align-items: start;
}

.item-large {
  padding: 20rpx;
}

.thumb {
  border-radius: 8rpx;
  background: #111827;
}

.thumb-medium {
  width: 180rpx;
  height: 140rpx;
}

.thumb-large {
  width: 100%;
  height: 520rpx;
  margin-bottom: 20rpx;
}

.video-card {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  word-break: break-all;
}
