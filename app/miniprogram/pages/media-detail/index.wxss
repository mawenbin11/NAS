.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.media-image,
.media-video {
  width: 100%;
  height: 620rpx;
  border-radius: 8rpx;
  background: #111827;
}

.section,
.empty,
.error {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  word-break: break-all;
}

.meta {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  word-break: break-all;
}

.error {
  color: #b42318;
}
